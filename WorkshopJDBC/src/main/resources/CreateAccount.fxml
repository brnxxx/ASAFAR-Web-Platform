<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.CreateAccountController"
           stylesheets="@create-account.css"
           styleClass="auth-background"
           prefWidth="900"
           prefHeight="700">

    <!-- ================= MAIN CARD ================= -->

    <VBox alignment="CENTER"
          spacing="25"
          maxWidth="420"
          styleClass="auth-card"
          StackPane.alignment="CENTER">

        <padding>
            <Insets top="40" right="35" bottom="40" left="35"/>
        </padding>

        <!-- ================= AVATAR ================= -->

        <StackPane>
            <Circle radius="45" styleClass="avatar-circle"/>

            <ImageView fitWidth="55" preserveRatio="true">
                <image>
                    <Image url="@/images/avatar.png"/>
                </image>
            </ImageView>
        </StackPane>

        <!-- ================= TITLE ================= -->

        <Label text="Créer un Compte"
               styleClass="auth-title"/>

        <!-- ================= FORM ================= -->

        <VBox spacing="14"
              alignment="CENTER"
              maxWidth="360">

            <ImageView fx:id="imageViewUser"
                       fitHeight="120"
                       fitWidth="120" />

            <Button text="Choisir image"
                    onAction="#handleUploadImage"/>



            <!-- ========= NOM ========= -->
            <VBox spacing="4" alignment="CENTER_LEFT">

                <HBox spacing="12"
                      alignment="CENTER_LEFT"
                      styleClass="input-wrapper">

                    <Label text="👤" styleClass="input-icon"/>

                    <TextField fx:id="tfNom"
                               promptText="Nom"
                               styleClass="input-field"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label fx:id="errNom"
                       styleClass="error-text"
                       visible="false"
                       managed="false"/>
            </VBox>

            <!-- ========= PRENOM ========= -->
            <VBox spacing="4" alignment="CENTER_LEFT">

                <HBox spacing="12"
                      alignment="CENTER_LEFT"
                      styleClass="input-wrapper">

                    <Label text="👤" styleClass="input-icon"/>

                    <TextField fx:id="tfPrenom"
                               promptText="Prénom"
                               styleClass="input-field"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label fx:id="errPrenom"
                       styleClass="error-text"
                       visible="false"
                       managed="false"/>
            </VBox>

            <!-- ========= EMAIL ========= -->
            <VBox spacing="4" alignment="CENTER_LEFT">

                <HBox spacing="12"
                      alignment="CENTER_LEFT"
                      styleClass="input-wrapper">

                    <Label text="📧" styleClass="input-icon"/>

                    <TextField fx:id="tfEmail"
                               promptText="Email"
                               styleClass="input-field"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label fx:id="errEmail"
                       styleClass="error-text"
                       visible="false"
                       managed="false"/>
            </VBox>

            <!-- ========= TELEPHONE ========= -->
            <VBox spacing="4" alignment="CENTER_LEFT">

                <HBox spacing="12"
                      alignment="CENTER_LEFT"
                      styleClass="input-wrapper">

                    <Label text="☎" styleClass="input-icon"/>

                    <TextField fx:id="tfTel"
                               promptText="Téléphone (8 chiffres)"
                               styleClass="input-field"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label fx:id="errTel"
                       styleClass="error-text"
                       visible="false"
                       managed="false"/>
            </VBox>

            <!-- ========= PASSWORD ========= -->
            <VBox spacing="4" alignment="CENTER_LEFT">

                <HBox spacing="12"
                      alignment="CENTER_LEFT"
                      styleClass="input-wrapper">

                    <Label text="🔒" styleClass="input-icon"/>

                    <PasswordField fx:id="tfPassword"
                                   promptText="Mot de passe"
                                   styleClass="input-field"
                                   HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label fx:id="errPassword"
                       styleClass="error-text"
                       visible="false"
                       managed="false"/>
            </VBox>

            <!-- ========= CONFIRM PASSWORD ========= -->
            <VBox spacing="4" alignment="CENTER_LEFT">

                <HBox spacing="12"
                      alignment="CENTER_LEFT"
                      styleClass="input-wrapper">

                    <Label text="🔐" styleClass="input-icon"/>

                    <PasswordField fx:id="tfConfirmPassword"
                                   promptText="Confirmer mot de passe"
                                   styleClass="input-field"
                                   HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label fx:id="errConfirm"
                       styleClass="error-text"
                       visible="false"
                       managed="false"/>
            </VBox>

        </VBox>

        <!-- ================= BUTTON ================= -->
        <Label fx:id="lblError"
               text=""
               visible="false"
               managed="false"
               styleClass="error-label"
               wrapText="true"/>

        <Button text="Créer mon compte"
                styleClass="btn-auth"
                prefWidth="260"
                onAction="#handleCreateAccount"/>

        <!-- ================= LOGIN LINK ================= -->

        <HBox alignment="CENTER" spacing="5">
            <Label text="Déjà un compte ?"
                   styleClass="auth-text"/>

            <Hyperlink text="Se connecter"
                       styleClass="auth-link"
                       onAction="#handleLoginRedirect"/>
        </HBox>

    </VBox>

</StackPane>
