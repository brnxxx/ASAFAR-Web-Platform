{% extends 'admin/base.html.twig' %}

{% block title %}Assistant IA{% endblock %}
{% block page_icon %}fas fa-robot{% endblock %}
{% block page_title %}Assistant Base de Données{% endblock %}
{% block breadcrumb %}Assistant IA{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  :root {
    --chat-bg: #0f1117;
    --chat-surface: #1a1d27;
    --chat-border: #2a2d3e;
    --chat-accent: #6366f1;
    --chat-accent-soft: rgba(99,102,241,0.12);
    --chat-green: #10b981;
    --chat-red: #ef4444;
    --chat-text: #e2e8f0;
    --chat-muted: #64748b;
    --chat-user-bg: #6366f1;
    --chat-bot-bg: #1e2130;
    --sql-bg: #0d1117;
    --sql-border: #30363d;
    --radius: 14px;
    --radius-sm: 8px;
  }
  .chatbot-wrapper {
    display: grid;
    grid-template-columns: 260px 1fr;
    height: calc(100vh - 140px);
    background: var(--chat-bg);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--chat-border);
    font-family: 'DM Sans', 'Segoe UI', sans-serif;
  }
  .chat-sidebar {
    background: var(--chat-surface);
    border-right: 1px solid var(--chat-border);
    display: flex; flex-direction: column;
    padding: 16px; gap: 12px;
    overflow-y: auto;
  }
  .chat-logo { display: flex; align-items: center; gap: 10px; padding-bottom: 12px; border-bottom: 1px solid var(--chat-border); }
  .chat-logo-icon { width: 36px; height: 36px; background: linear-gradient(135deg,#6366f1,#8b5cf6); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .chat-logo h2 { font-size: 14px; font-weight: 600; color: var(--chat-text); margin: 0; }
  .chat-logo span { font-size: 11px; color: var(--chat-muted); }
  .ollama-status { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-radius: var(--radius-sm); border: 1px solid var(--chat-border); font-size: 12px; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .status-dot.online  { background: var(--chat-green); box-shadow: 0 0 6px var(--chat-green); }
  .status-dot.offline { background: var(--chat-red);   box-shadow: 0 0 6px var(--chat-red); }
  .sidebar-section-title { font-size: 10px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--chat-muted); padding: 0 4px; }
  .suggestion-btn { background: transparent; border: 1px solid var(--chat-border); border-radius: var(--radius-sm); color: #94a3b8; font-size: 12px; padding: 8px 10px; text-align: left; cursor: pointer; transition: all .2s; width: 100%; }
  .suggestion-btn:hover { background: var(--chat-accent-soft); border-color: var(--chat-accent); color: var(--chat-text); }
  .sidebar-actions { margin-top: auto; display: flex; flex-direction: column; gap: 8px; }
  .action-btn { display: flex; align-items: center; gap: 8px; padding: 8px 12px; border-radius: var(--radius-sm); background: transparent; border: 1px solid var(--chat-border); color: var(--chat-muted); font-size: 12px; cursor: pointer; transition: all .2s; width: 100%; }
  .action-btn:hover { background: rgba(255,255,255,0.04); color: var(--chat-text); }
  .chat-main { display: flex; flex-direction: column; background: var(--chat-bg); overflow: hidden; }
  .chat-header { padding: 14px 20px; border-bottom: 1px solid var(--chat-border); display: flex; align-items: center; justify-content: space-between; }
  .chat-header h1 { font-size: 14px; font-weight: 600; color: var(--chat-text); margin: 0; }
  .chat-header p { font-size: 11px; color: var(--chat-muted); margin: 2px 0 0; }
  .model-badge { background: var(--chat-accent-soft); border: 1px solid rgba(99,102,241,.3); color: #a5b4fc; font-size: 11px; padding: 3px 8px; border-radius: 20px; }
  .chat-messages { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 16px; scroll-behavior: smooth; }
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--chat-border); border-radius: 2px; }
  .message { display: flex; gap: 10px; max-width: 88%; }
  .message.user { flex-direction: row-reverse; align-self: flex-end; }
  .message.bot  { align-self: flex-start; }
  .msg-avatar { width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 13px; }
  .message.user .msg-avatar { background: var(--chat-user-bg); }
  .message.bot  .msg-avatar { background: var(--chat-bot-bg); border: 1px solid var(--chat-border); }
  .msg-content { display: flex; flex-direction: column; gap: 4px; }
  .msg-bubble { padding: 10px 14px; border-radius: var(--radius); font-size: 13px; line-height: 1.6; }
  .message.user .msg-bubble { background: var(--chat-user-bg); color: #fff; border-bottom-right-radius: 4px; }
  .message.bot  .msg-bubble { background: var(--chat-bot-bg); color: var(--chat-text); border: 1px solid var(--chat-border); border-bottom-left-radius: 4px; }
  .msg-time { font-size: 10px; color: var(--chat-muted); padding: 0 4px; }
  .message.user .msg-time { text-align: right; }
  .sql-block { margin-top: 8px; border-radius: var(--radius-sm); border: 1px solid var(--sql-border); overflow: hidden; font-size: 12px; }
  .sql-block-header { background: #161b22; padding: 5px 10px; display: flex; align-items: center; justify-content: space-between; color: #7d8590; font-size: 11px; font-family: monospace; }
  .sql-copy-btn { background: transparent; border: none; color: #7d8590; cursor: pointer; font-size: 11px; padding: 2px 6px; border-radius: 4px; }
  .sql-copy-btn:hover { color: #e2e8f0; }
  .sql-code { background: var(--sql-bg); padding: 10px 12px; color: #79c0ff; font-family: 'JetBrains Mono', monospace; white-space: pre-wrap; word-break: break-all; line-height: 1.5; }
  .results-block { margin-top: 8px; border-radius: var(--radius-sm); border: 1px solid var(--chat-border); overflow: hidden; }
  .results-header { background: #1a2332; padding: 6px 10px; font-size: 11px; color: var(--chat-muted); display: flex; align-items: center; gap: 6px; }
  .results-count { background: rgba(16,185,129,.15); color: #10b981; padding: 1px 6px; border-radius: 10px; font-weight: 600; }
  .results-table-wrap { overflow-x: auto; max-height: 240px; overflow-y: auto; }
  .results-table { width: 100%; border-collapse: collapse; font-size: 11px; font-family: monospace; }
  .results-table th { background: #161b22; color: #7d8590; padding: 6px 10px; text-align: left; white-space: nowrap; font-weight: 500; border-bottom: 1px solid var(--sql-border); position: sticky; top: 0; }
  .results-table td { padding: 5px 10px; color: #c9d1d9; border-bottom: 1px solid rgba(48,54,61,.5); white-space: nowrap; max-width: 180px; overflow: hidden; text-overflow: ellipsis; }
  .results-table tr:last-child td { border-bottom: none; }
  .results-table tr:hover td { background: rgba(99,102,241,.05); }
  .typing-indicator { display: flex; align-items: center; gap: 4px; padding: 4px 0; }
  .typing-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--chat-muted); animation: typingPulse 1.4s ease-in-out infinite; }
  .typing-dot:nth-child(2) { animation-delay: .2s; }
  .typing-dot:nth-child(3) { animation-delay: .4s; }
  @keyframes typingPulse { 0%,60%,100%{opacity:.3;transform:scale(1)} 30%{opacity:1;transform:scale(1.2)} }
  .welcome-screen { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; height: 100%; text-align: center; padding: 40px; }
  .welcome-icon { width: 60px; height: 60px; background: linear-gradient(135deg,#6366f1,#8b5cf6); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 26px; box-shadow: 0 8px 32px rgba(99,102,241,.3); }
  .welcome-screen h2 { font-size: 18px; font-weight: 600; color: var(--chat-text); margin: 0; }
  .welcome-screen p { font-size: 13px; color: var(--chat-muted); max-width: 380px; line-height: 1.6; margin: 0; }
  .welcome-chips { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
  .welcome-chip { background: var(--chat-surface); border: 1px solid var(--chat-border); color: #94a3b8; padding: 6px 12px; border-radius: 20px; font-size: 12px; cursor: pointer; transition: all .2s; }
  .welcome-chip:hover { background: var(--chat-accent-soft); border-color: var(--chat-accent); color: var(--chat-text); }
  .chat-input-area { padding: 12px 20px 16px; border-top: 1px solid var(--chat-border); }
  .chat-input-wrap { display: flex; align-items: flex-end; gap: 8px; background: var(--chat-surface); border: 1px solid var(--chat-border); border-radius: var(--radius); padding: 8px 10px; transition: border-color .2s; }
  .chat-input-wrap:focus-within { border-color: var(--chat-accent); }
  #chatInput { flex: 1; background: transparent; border: none; outline: none; color: var(--chat-text); font-size: 13px; resize: none; min-height: 20px; max-height: 100px; line-height: 1.5; font-family: inherit; }
  #chatInput::placeholder { color: var(--chat-muted); }
  #sendBtn { width: 34px; height: 34px; background: var(--chat-accent); border: none; border-radius: 8px; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s; flex-shrink: 0; }
  #sendBtn:hover:not(:disabled) { background: #4f46e5; }
  #sendBtn:disabled { opacity: .4; cursor: not-allowed; }
  .input-hint { font-size: 10px; color: var(--chat-muted); padding: 4px 2px 0; }
  .error-bubble { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.3); color: #fca5a5; padding: 8px 12px; border-radius: var(--radius-sm); font-size: 12px; margin-top: 4px; }
</style>
{% endblock %}

{% block content %}
<div class="chatbot-wrapper">

  {# SIDEBAR #}
  <aside class="chat-sidebar">
    <div class="chat-logo">
      <div class="chat-logo-icon">🤖</div>
      <div>
        <h2>DB Assistant</h2>
        <span>Powered by Ollama</span>
      </div>
    </div>

    <div class="ollama-status">
      <div class="status-dot {{ ollama_online ? 'online' : 'offline' }}" id="statusDot"></div>
      <div>
        <div style="color: {{ ollama_online ? '#10b981' : '#ef4444' }}; font-weight: 600; font-size:12px;" id="statusText">
          {{ ollama_online ? 'Ollama en ligne' : 'Ollama hors ligne' }}
        </div>
        <div style="color: var(--chat-muted); font-size: 10px;">llama3 · localhost:11434</div>
      </div>
    </div>

    <div class="sidebar-section-title">Suggestions</div>

    {% for s in [
      "Combien d'utilisateurs sont actifs ?",
      "Quelles sont les 5 dernières connexions ?",
      "Combien de connexions Face ID réussies ?",
      "Quels pays ont tenté de se connecter ?",
      "Combien d'utilisateurs ont un trust score > 70 ?",
      "Quelles IP ont eu des tentatives RISK_HIGH ?",
    ] %}
      <button class="suggestion-btn" onclick="useSuggestion(this.textContent.trim())">{{ s }}</button>
    {% endfor %}

    <div class="sidebar-actions">
      <button class="action-btn" onclick="clearChat()">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Nouvelle conversation
      </button>
      <button class="action-btn" onclick="exportChat()">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Exporter
      </button>
    </div>
  </aside>

  {# MAIN #}
  <div class="chat-main">
    <div class="chat-header">
      <div>
        <h1>Assistant Base de Données</h1>
        <p>Posez vos questions en français — l'IA génère et exécute le SQL</p>
      </div>
      <div class="model-badge">llama3</div>
    </div>

    <div class="chat-messages" id="chatMessages">
      <div class="welcome-screen" id="welcomeScreen">
        <div class="welcome-icon">🗄️</div>
        <h2>Interrogez votre base de données</h2>
        <p>Posez n'importe quelle question en français. L'IA générera la requête SQL et vous donnera une réponse claire.</p>
        <div class="welcome-chips">
          <span class="welcome-chip" onclick="useSuggestion(this.textContent)">Utilisateurs actifs</span>
          <span class="welcome-chip" onclick="useSuggestion(this.textContent)">Dernières connexions</span>
          <span class="welcome-chip" onclick="useSuggestion(this.textContent)">Tentatives suspectes</span>
          <span class="welcome-chip" onclick="useSuggestion(this.textContent)">Statistiques générales</span>
        </div>
      </div>
    </div>

    <div class="chat-input-area">
      <div class="chat-input-wrap">
        <textarea id="chatInput" placeholder="Ex : Combien d'utilisateurs se sont connectés aujourd'hui ?" rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
        <button id="sendBtn" onclick="sendMessage()">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
        </button>
      </div>
      <div class="input-hint">Entrée pour envoyer · Maj+Entrée pour aller à la ligne</div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
const CHAT_URL   = '{{ path('admin_chatbot_ask') }}';
const STATUS_URL = '{{ path('admin_chatbot_status') }}';
const EXPORT_URL = '{{ path('admin_chatbot_export') }}';

let history  = [];
let isLoading = false;

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function useSuggestion(text) {
  document.getElementById('chatInput').value = text;
  autoResize(document.getElementById('chatInput'));
  sendMessage();
}

async function sendMessage() {
  if (isLoading) return;
  const input    = document.getElementById('chatInput');
  const question = input.value.trim();
  if (!question) return;

  hideWelcome();
  appendUserMessage(question);
  history.push({ role: 'user', content: question });
  input.value = '';
  input.style.height = 'auto';
  setLoading(true);
  const typingId = appendTyping();

  try {
    const res  = await fetch(CHAT_URL, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ question, history: history.slice(-6) }),
    });
    const data = await res.json();
    removeTyping(typingId);

    if (data.error && !data.answer) {
      appendErrorMessage(data.error);
    } else {
      appendBotMessage(data.answer, data.sql, data.results, data.count);
      history.push({ role: 'assistant', content: data.answer });
    }
  } catch (err) {
    removeTyping(typingId);
    appendErrorMessage('Impossible de contacter le serveur.');
  } finally {
    setLoading(false);
  }
}

function hideWelcome() {
  const w = document.getElementById('welcomeScreen');
  if (w) w.remove();
}

function getTime() {
  return new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}

function appendUserMessage(text) {
  document.getElementById('chatMessages').insertAdjacentHTML('beforeend', `
    <div class="message user">
      <div class="msg-avatar">👤</div>
      <div class="msg-content">
        <div class="msg-bubble">${escHtml(text)}</div>
        <div class="msg-time">${getTime()}</div>
      </div>
    </div>`);
  scrollBottom();
}

function appendBotMessage(answer, sql, results, count) {
  let sqlHtml = '';
  if (sql) {
    const uid = 'sql_' + Date.now();
    sqlHtml = `<div class="sql-block">
      <div class="sql-block-header"><span>SQL exécuté</span><button class="sql-copy-btn" onclick="copySql('${uid}')">Copier</button></div>
      <pre class="sql-code" id="${uid}">${escHtml(sql)}</pre></div>`;
  }
  let tableHtml = '';
  if (results && results.length > 0) {
    const cols = Object.keys(results[0]);
    const rows = results.slice(0,50).map(row =>
      '<tr>' + cols.map(c => `<td title="${escHtml(String(row[c]??''))}">${escHtml(String(row[c]??''))}</td>`).join('') + '</tr>'
    ).join('');
    tableHtml = `<div class="results-block">
      <div class="results-header">Résultats <span class="results-count">${count}</span></div>
      <div class="results-table-wrap"><table class="results-table">
        <thead><tr>${cols.map(c=>`<th>${escHtml(c)}</th>`).join('')}</tr></thead>
        <tbody>${rows}</tbody>
      </table></div></div>`;
  } else if (results && results.length === 0) {
    tableHtml = `<div style="font-size:11px;color:var(--chat-muted);padding:6px 0">Aucun résultat.</div>`;
  }

  document.getElementById('chatMessages').insertAdjacentHTML('beforeend', `
    <div class="message bot">
      <div class="msg-avatar">🤖</div>
      <div class="msg-content">
        <div class="msg-bubble">${escHtml(answer)}${sqlHtml}${tableHtml}</div>
        <div class="msg-time">${getTime()}</div>
      </div>
    </div>`);
  scrollBottom();
}

function appendErrorMessage(msg) {
  document.getElementById('chatMessages').insertAdjacentHTML('beforeend', `
    <div class="message bot">
      <div class="msg-avatar">🤖</div>
      <div class="msg-content"><div class="error-bubble">${escHtml(msg)}</div></div>
    </div>`);
  scrollBottom();
}

function appendTyping() {
  const id = 'typing_' + Date.now();
  document.getElementById('chatMessages').insertAdjacentHTML('beforeend', `
    <div class="message bot" id="${id}">
      <div class="msg-avatar">🤖</div>
      <div class="msg-content"><div class="msg-bubble">
        <div class="typing-indicator">
          <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
        </div>
      </div></div>
    </div>`);
  scrollBottom();
  return id;
}

function removeTyping(id) { document.getElementById(id)?.remove(); }

function setLoading(v) {
  isLoading = v;
  document.getElementById('sendBtn').disabled   = v;
  document.getElementById('chatInput').disabled = v;
}

function scrollBottom() {
  const w = document.getElementById('chatMessages');
  w.scrollTop = w.scrollHeight;
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function copySql(id) {
  const el = document.getElementById(id);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = el.parentElement.querySelector('.sql-copy-btn');
    if (btn) { btn.textContent = 'Copié !'; setTimeout(() => btn.textContent = 'Copier', 2000); }
  });
}

function clearChat() {
  history = [];
  document.getElementById('chatMessages').innerHTML = `
    <div class="welcome-screen" id="welcomeScreen">
      <div class="welcome-icon">🗄️</div>
      <h2>Interrogez votre base de données</h2>
      <p>Posez n'importe quelle question en français.</p>
      <div class="welcome-chips">
        <span class="welcome-chip" onclick="useSuggestion(this.textContent)">Utilisateurs actifs</span>
        <span class="welcome-chip" onclick="useSuggestion(this.textContent)">Dernières connexions</span>
      </div>
    </div>`;
}

async function exportChat() {
  if (!history.length) { alert('Aucune conversation à exporter.'); return; }
  const res  = await fetch(EXPORT_URL, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({history}) });
  const blob = await res.blob();
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = 'chatbot-' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
}

async function pollOllamaStatus() {
  try {
    const res  = await fetch(STATUS_URL);
    const data = await res.json();
    const dot  = document.getElementById('statusDot');
    const txt  = document.getElementById('statusText');
    dot.className   = 'status-dot ' + (data.online ? 'online' : 'offline');
    txt.textContent = data.online ? 'Ollama en ligne' : 'Ollama hors ligne';
    txt.style.color = data.online ? '#10b981' : '#ef4444';
  } catch {}
}

setInterval(pollOllamaStatus, 15000);
</script>
{% endblock %}