<script>
    const toggleBtn = document.getElementById('toggle-post-form');
    const cancelBtn = document.getElementById('cancel-post-form');
    const formWrapper = document.getElementById('post-form-wrapper');
    const placeholder = document.getElementById('post-placeholder');

    function openPostForm() {
        if (formWrapper) {
            formWrapper.style.display = 'block';
        }
    }

    function closePostForm() {
        if (formWrapper) {
            formWrapper.style.display = 'none';
        }
    }

    toggleBtn?.addEventListener('click', (e) => {
        e.preventDefault();

        if (formWrapper.style.display === 'block') {
            closePostForm();
        } else {
            openPostForm();
            document.getElementById('post-title-input')?.focus();
        }
    });

    placeholder?.addEventListener('click', (e) => {
        e.preventDefault();
        openPostForm();
        document.getElementById('post-title-input')?.focus();
    });

    placeholder?.addEventListener('focus', (e) => {
        e.preventDefault();
        openPostForm();
        document.getElementById('post-title-input')?.focus();
    });

    cancelBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        closePostForm();
    });

    const imageInput = document.getElementById('post_image_input');
    const selectedFileName = document.getElementById('selected-file-name');
    const imagePreviewWrapper = document.getElementById('image-preview-wrapper');
    const imagePreview = document.getElementById('image-preview');

    imageInput?.addEventListener('change', function () {
        const file = this.files && this.files[0];

        if (!file) {
            selectedFileName.textContent = 'Aucun fichier sélectionné';
            imagePreviewWrapper.style.display = 'none';
            imagePreview.src = '';
            return;
        }

        selectedFileName.textContent = file.name;

        if (file.type.startsWith('image/')) {
            const reader = new FileReader();
            reader.onload = function (e) {
                imagePreview.src = e.target.result;
                imagePreviewWrapper.style.display = 'block';
            };
            reader.readAsDataURL(file);
        }
    });

    document.querySelectorAll('.like-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();
            const postId = btn.dataset.postId;

            try {
                const response = await fetch(`/posts/api/post/${postId}/like`, { method: 'POST' });
                if (response.ok) {
                    btn.classList.toggle('liked');
                    const countElement = btn.querySelector('.like-count');
                    const currentCount = parseInt(countElement.textContent, 10) || 0;
                    countElement.textContent = btn.classList.contains('liked') ? currentCount + 1 : Math.max(0, currentCount - 1);
                }
            } catch (error) {
                console.error('Erreur:', error);
            }
        });
    });

    const modal = document.getElementById('comment-modal');
    const closeCommentBtn = document.getElementById('close-modal');
    const commentForm = document.getElementById('comment-form');
    const modalPostId = document.getElementById('modal-post-id');
    const commentText = document.getElementById('comment-text');
    const commentGifUrlInput = document.getElementById('comment-gif-url');
    const selectedGifPreview = document.getElementById('selected-gif-preview');
    const selectedGifImage = document.getElementById('selected-gif-image');
    const removeSelectedGifBtn = document.getElementById('remove-selected-gif');
    const openGifSearchBtn = document.getElementById('open-gif-search');
    const gifSearchBox = document.getElementById('gif-search-box');
    const gifSearchInput = document.getElementById('gif-search-input');
    const gifSearchBtn = document.getElementById('gif-search-btn');
    const gifResults = document.getElementById('gif-results');

    const GIPHY_API_KEY = 'JhHMwrAg0MZunIACnJkHKQGHnRzJwciH';

    function resetCommentModal() {
    commentForm?.reset();

    hideCommentError();

    if (commentGifUrlInput) {
        commentGifUrlInput.value = '';
    }

    if (selectedGifImage) {
        selectedGifImage.src = '';
    }

    if (selectedGifPreview) {
        selectedGifPreview.style.display = 'none';
    }

    if (gifResults) {
        gifResults.innerHTML = '';
    }

    if (gifSearchInput) {
        gifSearchInput.value = '';
    }

    if (gifSearchBox) {
        gifSearchBox.style.display = 'none';
    }
}

    document.querySelectorAll('.comment-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            modalPostId.value = btn.dataset.postId;
            modal.style.display = 'flex';
            commentText?.focus();
        });
    });

    closeCommentBtn?.addEventListener('click', () => {
        modal.style.display = 'none';
        resetCommentModal();
    });

    modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.style.display = 'none';
            resetCommentModal();
        }
    });

    openGifSearchBtn?.addEventListener('click', () => {
        gifSearchBox.style.display = gifSearchBox.style.display === 'none' || gifSearchBox.style.display === '' ? 'block' : 'none';
        gifSearchInput?.focus();
    });

    removeSelectedGifBtn?.addEventListener('click', () => {
        commentGifUrlInput.value = '';
        selectedGifImage.src = '';
        selectedGifPreview.style.display = 'none';
    });

    async function searchGifs() {
        const query = gifSearchInput.value.trim();

        if (!query) {
            gifResults.innerHTML = '';
            return;
        }

        gifResults.innerHTML = '<div style="color:#f4f8fc;">Chargement...</div>';

        try {
            const url = `https://api.giphy.com/v1/gifs/search?api_key=${GIPHY_API_KEY}&q=${encodeURIComponent(query)}&limit=9&rating=g&lang=fr`;
            const response = await fetch(url);
            const data = await response.json();

            const gifs = data.data || [];

            if (gifs.length === 0) {
                gifResults.innerHTML = '<div style="color:#f4f8fc;">Aucun GIF trouvé.</div>';
                return;
            }

            gifResults.innerHTML = gifs.map(gif => {
    const preview = gif.images.fixed_width_small?.url || gif.images.fixed_width?.url;
    const original = gif.images.original?.url || preview;

    return `
        <img
            src="${preview}"
            data-gif-url="${original}"
            alt="GIF"
            class="gif-result-item"
            loading="lazy"
        >
    `;
}).join('');

           document.querySelectorAll('.gif-result-item').forEach(item => {
    item.addEventListener('click', () => {
        const gifUrl = item.getAttribute('data-gif-url');
        commentGifUrlInput.value = gifUrl;
        selectedGifImage.src = gifUrl;
        selectedGifPreview.style.display = 'block';
        gifSearchBox.style.display = 'none';
    });
});

        } catch (error) {
            console.error('Erreur GIPHY:', error);
            gifResults.innerHTML = '<div style="color:#ffb3b3;">Erreur lors du chargement des GIFs.</div>';
        }
    }

    gifSearchBtn?.addEventListener('click', searchGifs);

    gifSearchInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchGifs();
        }
    });

   const commentErrorMessage = document.getElementById('comment-error-message');

function hideCommentError() {
    if (commentErrorMessage) {
        commentErrorMessage.style.display = 'none';
        commentErrorMessage.textContent = '';
    }
}

function showCommentError(message) {
    if (commentErrorMessage) {
        commentErrorMessage.textContent = message;
        commentErrorMessage.style.display = 'block';
    }
}

commentText?.addEventListener('input', hideCommentError);

commentForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    hideCommentError();

    const postId = modalPostId.value;
    const content = commentText.value;
    const gifUrl = commentGifUrlInput.value;

    try {
        const response = await fetch(`/posts/api/post/${postId}/comment`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                contenu: content,
                gifUrl: gifUrl
            })
        });

        const data = await response.json();

        if (response.ok) {
            modal.style.display = 'none';
            resetCommentModal();
            location.reload();
            return;
        }

        let errorMessage = data.error || 'Erreur lors de l’ajout du commentaire.';

        if (Array.isArray(data.matchedWords) && data.matchedWords.length > 0) {
            errorMessage += ' Mots détectés : ' + data.matchedWords.join(', ');
        }

        showCommentError(errorMessage);
    } catch (error) {
        console.error('Erreur:', error);
        showCommentError('Erreur serveur lors de l’ajout du commentaire.');
    }
});

    const editModal = document.getElementById('edit-comment-modal');
    const closeEditBtn = document.getElementById('close-edit-modal');
    const editCommentForm = document.getElementById('edit-comment-form');
    const editModalCommentId = document.getElementById('edit-modal-comment-id');
    const editCommentText = document.getElementById('edit-comment-text');

    document.querySelectorAll('.edit-comment-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            editModalCommentId.value = btn.dataset.commentId;
            editCommentText.value = btn.dataset.content;
            editModal.style.display = 'flex';
            editCommentText.focus();
        });
    });

    closeEditBtn?.addEventListener('click', () => {
        editModal.style.display = 'none';
        editCommentForm.reset();
    });

    editModal?.addEventListener('click', (e) => {
        if (e.target === editModal) {
            editModal.style.display = 'none';
            editCommentForm.reset();
        }
    });

    editCommentForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const commentId = editModalCommentId.value;
        const content = editCommentText.value;

        try {
            const response = await fetch(`/posts/api/comment/${commentId}/edit`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ contenu: content })
            });

            if (response.ok) {
                editModal.style.display = 'none';
                editCommentForm.reset();
                location.reload();
            }
        } catch (error) {
            console.error('Erreur:', error);
        }
    });

    const editPostModal = document.getElementById('edit-post-modal');
    const closeEditPostModal = document.getElementById('close-edit-post-modal');
    const editPostForm = document.getElementById('edit-post-form');
    const editPostTitle = document.getElementById('edit-post-title');
    const editPostType = document.getElementById('edit-post-type');
    const editPostContent = document.getElementById('edit-post-content');
    const editPostImage = document.getElementById('edit-post-image');
    const editSelectedFileName = document.getElementById('edit-selected-file-name');
    const editCurrentImageWrap = document.getElementById('edit-current-image-wrap');
    const editCurrentImage = document.getElementById('edit-current-image');
    const editImagePreviewWrapper = document.getElementById('edit-image-preview-wrapper');
    const editImagePreview = document.getElementById('edit-image-preview');
    const saveEditPostBtn = document.getElementById('save-edit-post-btn');

    document.querySelectorAll('.open-edit-post-modal').forEach(btn => {
        btn.addEventListener('click', () => {
            editPostForm.action = btn.dataset.editUrl;
            editPostTitle.value = btn.dataset.postTitle || '';
            editPostType.value = btn.dataset.postType || 'Promotion';
            editPostContent.value = btn.dataset.postContent || '';

            const currentImage = btn.dataset.postImage || '';
            if (currentImage) {
                editCurrentImage.src = currentImage;
                editCurrentImageWrap.style.display = 'block';
            } else {
                editCurrentImage.src = '';
                editCurrentImageWrap.style.display = 'none';
            }

            editPostImage.value = '';
            editSelectedFileName.textContent = 'Aucun nouveau fichier sélectionné';
            editImagePreviewWrapper.style.display = 'none';
            editImagePreview.src = '';

            editPostModal.style.display = 'flex';
        });
    });

    closeEditPostModal?.addEventListener('click', () => {
        editPostModal.style.display = 'none';
    });

    editPostModal?.addEventListener('click', (e) => {
        if (e.target === editPostModal) {
            editPostModal.style.display = 'none';
        }
    });

    editPostImage?.addEventListener('change', function () {
        const file = this.files && this.files[0];

        if (!file) {
            editSelectedFileName.textContent = 'Aucun nouveau fichier sélectionné';
            editImagePreviewWrapper.style.display = 'none';
            editImagePreview.src = '';
            return;
        }

        editSelectedFileName.textContent = file.name;

        if (file.type.startsWith('image/')) {
            const reader = new FileReader();
            reader.onload = function (e) {
                editImagePreview.src = e.target.result;
                editImagePreviewWrapper.style.display = 'block';
            };
            reader.readAsDataURL(file);
        }
    });

    editPostForm?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(editPostForm);

        saveEditPostBtn.disabled = true;
        saveEditPostBtn.textContent = 'Enregistrement...';

        try {
            const response = await fetch(editPostForm.action, {
                method: 'POST',
                body: formData
            });

            if (response.ok) {
                editPostModal.style.display = 'none';
                location.reload();
                return;
            }

            alert('Erreur lors de la modification du post.');
        } catch (error) {
            console.error('Erreur:', error);
            alert('Erreur lors de la modification du post.');
        } finally {
            saveEditPostBtn.disabled = false;
            saveEditPostBtn.textContent = 'Enregistrer';
        }
    });
document.querySelectorAll('.translate-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const postCard = btn.closest('.post-card');

        const titleEl = postCard.querySelector('.post-title');
        const contentEl = postCard.querySelector('.post-content');
        const select = postCard.querySelector('.translate-lang');

        const titleText = titleEl ? titleEl.innerText.trim() : '';
        const contentText = contentEl ? contentEl.innerText.trim() : '';
        const targetLang = select.value;

        const oldBtnText = btn.textContent;
        btn.textContent = '⏳ Traduction...';
        btn.disabled = true;

        try {
            const response = await fetch('/posts/api/translate', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    title: titleText,
                    text: contentText,
                    target: targetLang
                })
            });

            const rawText = await response.text();
            let data = null;

            try {
                data = JSON.parse(rawText);
            } catch (e) {
                console.error('Réponse non JSON :', rawText);
                alert('Le serveur a renvoyé du HTML au lieu de JSON.');
                return;
            }

            if (!response.ok) {
                console.error('Erreur backend traduction :', data);
                alert((data.error || 'Erreur') + '\n' + (data.details || ''));
                return;
            }

            if (titleEl && data.translatedTitle) {
                titleEl.innerText = data.translatedTitle;
            }

            if (contentEl && data.translatedText) {
                contentEl.innerText = data.translatedText;
            }

        } catch (error) {
            console.error('Erreur fetch :', error);
            alert('Erreur JS/fetch : ' + error.message);
        } finally {
            btn.textContent = oldBtnText;
            btn.disabled = false;
        }
    });
});
const reportModal = document.getElementById('report-modal');
const closeReportModalBtn = document.getElementById('close-report-modal');
const reportForm = document.getElementById('report-form');
const reportPostIdInput = document.getElementById('report-post-id');
const reportReasonInput = document.getElementById('report-reason');
const reportDetailsInput = document.getElementById('report-details');
const reportErrorMessage = document.getElementById('report-error-message');
const reportSuccessMessage = document.getElementById('report-success-message');

function resetReportModal() {
    if (reportForm) {
        reportForm.reset();
    }

    if (reportErrorMessage) {
        reportErrorMessage.style.display = 'none';
        reportErrorMessage.textContent = '';
    }

    if (reportSuccessMessage) {
        reportSuccessMessage.style.display = 'none';
        reportSuccessMessage.textContent = '';
    }

    if (reportPostIdInput) {
        reportPostIdInput.value = '';
    }
}

document.querySelectorAll('.report-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        if (reportPostIdInput) {
            reportPostIdInput.value = btn.dataset.postId;
        }

        if (reportModal) {
            reportModal.style.display = 'flex';
        }

        reportReasonInput?.focus();
    });
});

closeReportModalBtn?.addEventListener('click', () => {
    if (reportModal) {
        reportModal.style.display = 'none';
    }
    resetReportModal();
});

reportModal?.addEventListener('click', (e) => {
    if (e.target === reportModal) {
        reportModal.style.display = 'none';
        resetReportModal();
    }
});

reportForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (reportErrorMessage) {
        reportErrorMessage.style.display = 'none';
        reportErrorMessage.textContent = '';
    }

    if (reportSuccessMessage) {
        reportSuccessMessage.style.display = 'none';
        reportSuccessMessage.textContent = '';
    }

    const postId = reportPostIdInput.value;
    const raison = reportReasonInput.value.trim();
    const details = reportDetailsInput.value.trim();

    if (!raison) {
        reportErrorMessage.textContent = 'Veuillez choisir une raison.';
        reportErrorMessage.style.display = 'block';
        return;
    }

    try {
        const response = await fetch(`/posts/api/post/${postId}/report`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                raison: raison,
                details: details
            })
        });

        const data = await response.json();
if (!response.ok) {
    reportErrorMessage.textContent =
        (data.error || 'Erreur lors du signalement.') +
        (data.details ? ' | ' + data.details : '');
    reportErrorMessage.style.display = 'block';
    return;
}

        reportSuccessMessage.textContent = data.message || 'Signalement envoyé avec succès.';
        reportSuccessMessage.style.display = 'block';

        setTimeout(() => {
            reportModal.style.display = 'none';
            resetReportModal();
        }, 1200);

    } catch (error) {
        console.error('Erreur signalement:', error);
        reportErrorMessage.textContent = 'Erreur serveur lors du signalement.';
        reportErrorMessage.style.display = 'block';
    }
});
const newsModal = document.getElementById('news-modal');
const openNewsBtn = document.getElementById('open-news-modal');
const closeNewsBtn = document.getElementById('close-news-modal');
const refreshNewsBtn = document.getElementById('refresh-news-btn');
const newsContainer = document.getElementById('news-container');

let newsLoading = false;
let lastNewsFetchTime = 0;

async function loadNews(force = false) {
    const now = Date.now();

    if (newsLoading) {
        return;
    }

    if (!force && now - lastNewsFetchTime < 5000) {
        return;
    }

    newsLoading = true;
    lastNewsFetchTime = now;

    if (refreshNewsBtn) {
        refreshNewsBtn.disabled = true;
        refreshNewsBtn.textContent = 'Chargement...';
    }

    newsContainer.innerHTML = 'Chargement des news...';

    try {
        const response = await fetch('/posts/api/news');
        const data = await response.json();

        if (!response.ok) {
            newsContainer.innerHTML = 'Erreur chargement news';
            return;
        }

        const articles = data.news || [];

        if (articles.length === 0) {
            newsContainer.innerHTML = 'Aucune news disponible.';
            return;
        }

        newsContainer.innerHTML = articles.map(article => `
            <div style="
                background:rgba(255,255,255,0.05);
                border-radius:16px;
                padding:16px;
                margin-bottom:16px;
            ">
                ${article.image ? `<img src="${article.image}" style="width:100%; border-radius:12px; margin-bottom:10px;">` : ''}

                <h3 style="color:#FFC107;">${article.title || ''}</h3>

                <p style="color:#f4f8fc;">${article.description || ''}</p>

                <a href="${article.url}" target="_blank" style="color:#2ea8ff; font-weight:bold;">
                    Lire plus →
                </a>
            </div>
        `).join('');
    } catch (error) {
        console.error('Erreur news:', error);
        newsContainer.innerHTML = 'Erreur serveur';
    } finally {
        newsLoading = false;

        if (refreshNewsBtn) {
            refreshNewsBtn.disabled = false;
            refreshNewsBtn.textContent = '🔄 Actualiser';
        }
    }
}

openNewsBtn?.addEventListener('click', async () => {
    newsModal.style.display = 'block';
    await loadNews(true);
});

refreshNewsBtn?.addEventListener('click', async () => {
    await loadNews(true);
});

closeNewsBtn?.addEventListener('click', () => {
    newsModal.style.display = 'none';
});

newsModal?.addEventListener('click', (e) => {
    if (e.target === newsModal) {
        newsModal.style.display = 'none';
    }
});


</script>
