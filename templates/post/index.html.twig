{% extends 'base.html.twig' %}

{% block title %}Fil d'actualité{% endblock %}

{% block body %}
<section class="feed-page">
    <div class="feed-layout">
        <div class="feed-column">
            <div style="display:flex; justify-content:space-between; align-items:center;">
    <h1 class="feed-title">Fil d'actualité</h1>

    <button id="open-news-modal" style="
        padding: 10px 18px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #2ea8ff, #1d7fe2);
        color: white;
        font-weight: 700;
        cursor: pointer;
    ">
        📰 News
    </button>
</div>

            {% for message in app.flashes('success') %}
                <div class="flash-message flash-success">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="flash-message flash-error">
                    {{ message }}
                </div>
            {% endfor %}

            <div class="create-post-card">
                <div class="create-post-top">
                    {% if app.user %}
    <div class="user-avatar">
        {{ app.user.nom|default('U')|first }}{{ app.user.prenom|default('')|first }}
    </div>
{% endif %}
                    <div class="create-post-input-wrap">
                        <input
                            type="text"
                            id="post-placeholder"
                            placeholder="Quoi de neuf ?"
                            class="fake-post-input"
                            readonly
                        >
                    </div>

                    <button type="button" id="toggle-post-form" class="create-post-plus">+</button>
                </div>

                <div id="post-form-wrapper" style="display: none;" class="post-form-wrapper">
                    {{ form_start(postForm, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="post-form-grid">

                        {{ form_widget(postForm.titre, {
                            'attr': {
                                'placeholder': 'Titre du post...',
                                'class': 'post-input-field',
                                'id': 'post-title-input'
                            }
                        }) }}

                        {{ form_widget(postForm.type, {
                            'attr': {
                                'class': 'post-input-field'
                            }
                        }) }}

                    </div>

                    <div class="post-form-block">

                        {{ form_widget(postForm.contenu, {
                            'attr': {
                                'placeholder': 'Écrire quelque chose...',
                                'rows': 4,
                                'class': 'post-textarea-field',
                                'id': 'post-content-textarea'
                            }
                        }) }}

                    </div>

                    <div class="post-form-block">
                        <div class="native-upload-box">
                            <div class="native-upload-title">📷 Ajouter une image</div>
                            <div class="native-upload-subtitle">Choisis directement une image depuis ton appareil</div>

                            {{ form_widget(postForm.imagePath, {
                                'attr': {
                                    'id': 'post_image_input',
                                    'class': 'native-file-input',
                                    'accept': 'image/*'
                                }
                            }) }}

                            <div id="selected-file-name" class="selected-file-name">Aucun fichier sélectionné</div>
                        </div>

                        <div id="image-preview-wrapper" style="display: none; margin-top: 14px;">
                            <img id="image-preview" src="" alt="Aperçu de l'image" class="preview-image">
                        </div>
                    </div>

                    <div class="post-form-block">
                        <div class="schedule-box">
                            <div class="schedule-title">⏰ Planifier la publication</div>
                            <div class="schedule-subtitle">Choisis une date et une heure pour publier plus tard</div>

                            <input
                                type="datetime-local"
                                name="scheduled_at"
                                id="scheduled_at"
                                class="post-input-field"
                            >
                        </div>
                    </div>

                    <div class="post-form-actions">
                        <button type="button" id="cancel-post-form" class="btn-cancel-post">
                            Annuler
                        </button>

                        <button type="submit" name="post_action" value="schedule" class="btn-plan-post">
                            Planifier
                        </button>

                        <button type="submit" name="post_action" value="publish" class="btn-submit-post">
                            Publier
                        </button>
                    </div>

                    {{ form_end(postForm) }}
                </div>
            </div>

            {% if posts is empty %}
                <div class="empty-post-card">
                    <div style="font-size: 48px; margin-bottom: 12px;">📭</div>
                    Aucun post pour le moment.
                </div>
            {% endif %}

           {% for post in posts %}
    {% set postAuthorName = post.user ? (post.user.nom ~ ' ' ~ post.user.prenom) : 'Auteur inconnu' %}
    {% set postAuthorInitials = post.user ? ((post.user.nom|first) ~ (post.user.prenom|first)) : 'AI' %}

    <article class="post-card" data-post-id="{{ post.id }}">
        <div class="post-header">
            <div class="post-author-wrap">
                <div class="user-avatar">
                    {{ postAuthorInitials }}
                </div>

                <div>
                    <h3 class="post-author-name">{{ postAuthorName }}</h3>
                    <p class="post-date">
                        {{ post.publishedAt ? post.publishedAt|date('d/m/Y H:i') : (post.createdAt ? post.createdAt|date('d/m/Y H:i') : '') }}
                    </p>
                </div>
            </div>

            <div class="post-type-badge">
                {{ post.type }}
            </div>
        </div>

                    <h2 class="post-title">{{ post.titre }}</h2>

                    <p class="post-content">{{ post.contenu }}</p>

                    {% if post.imagePath %}
                        <div class="post-image-wrap">
                            <img src="{{ asset(post.imagePath) }}" alt="image post" class="post-image">
                        </div>
                    {% endif %}

                    <div class="post-actions-row">
                        <button type="button" class="like-btn post-action-btn like-action" data-post-id="{{ post.id }}">
                            <span class="like-icon">👍</span>
                            <span>J'aime</span>
                            <span class="like-count action-count">{{ post.postLikes|length }}</span>
                        </button>

                        <button type="button" class="comment-btn post-action-btn comment-action" data-post-id="{{ post.id }}">
                            <span>💬</span>
                            <span>Commenter</span>
                            <span class="comment-count action-count">{{ post.commentaires|length }}</span>
                        </button>
                        <select class="translate-lang post-action-btn" data-post-id="{{ post.id }}">
                             <option value="fr">🇫🇷 FR</option>
                             <option value="en">🇬🇧 EN</option>
                             <option value="ar">🇸🇦 AR</option>
                        </select>

<button type="button"
        class="translate-btn post-action-btn"
        data-post-id="{{ post.id }}">
    🌍 Traduire
</button>
<button type="button"
        class="report-btn post-action-btn report-action"
        data-post-id="{{ post.id }}">
    🚨 Signaler
</button>

                        {% if app.user and post.user and app.user.id == post.user.id %}
                            <button
                                type="button"
                                class="post-action-btn edit-action open-edit-post-modal"
                                data-post-id="{{ post.id }}"
                                data-post-title="{{ post.titre|e('html_attr') }}"
                                data-post-type="{{ post.type|e('html_attr') }}"
                                data-post-content="{{ post.contenu|e('html_attr') }}"
                                data-post-image="{{ post.imagePath ? asset(post.imagePath) : '' }}"
                                data-edit-url="{{ path('app_post_edit', {'id': post.id}) }}"
                            >
                                <span>✏️</span>
                                <span>Modifier</span>
                            </button>

                            <form method="post" action="{{ path('app_post_delete', {'id': post.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce post ?')">
                                <button type="submit" class="post-action-btn delete-action">
                                    <span>🗑️</span>
                                    <span>Supprimer</span>
                                </button>
                            </form>
                        {% endif %}
                    </div>

                    {% if post.commentaires|length > 0 %}
                        <div class="comments-section">
                            <div class="comments-title">COMMENTAIRES ({{ post.commentaires|length }})</div>

                            {% for comment in post.commentaires %}
                                <div class="comment-card">
                                    <div class="comment-avatar">
                                        {% if comment.user %}{{ comment.user.nom|first }}{{ comment.user.prenom|first }}{% else %}U{% endif %}
                                    </div>

                                    <div style="flex: 1;">
                                        <p class="comment-author">
                                            {% if comment.user %}{{ comment.user.nom }} {{ comment.user.prenom }}{% else %}Utilisateur supprimé{% endif %}
                                        </p>

                                        {% if comment.contenu %}
                                            <p class="comment-content-text">{{ comment.contenu }}</p>
                                        {% endif %}

                                        {% if comment.gifUrl %}
                                            <div style="margin-top: 8px;">
                                                <img
                                                    src="{{ comment.gifUrl }}"
                                                    alt="GIF commentaire"
                                                    style="max-width: 220px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);"
                                                >
                                            </div>
                                        {% endif %}

                                        <p class="comment-date">{{ comment.createdAt ? comment.createdAt|date('d/m/Y H:i') : '' }}</p>

                                        {% if app.user and comment.user and app.user.id == comment.user.id %}
                                            <div class="comment-actions">
                                                <button type="button" class="edit-comment-btn mini-btn mini-edit" data-comment-id="{{ comment.id }}" data-content="{{ comment.contenu }}">
                                                    ✏️ Modifier
                                                </button>

                                                <form method="post" action="{{ path('api_comment_delete', {'id': comment.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce commentaire ?')">
                                                    <button type="submit" class="mini-btn mini-delete">
                                                        🗑️ Supprimer
                                                    </button>
                                                </form>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<div id="edit-comment-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; backdrop-filter: blur(4px); align-items: center; justify-content: center;">
    <div style="background: #0B2D4A; border: 1px solid rgba(255, 193, 7, 0.2); border-radius: 20px; padding: 32px; max-width: 500px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.5);">
        <h2 style="font-size: 24px; font-weight: 800; margin: 0 0 24px; color: #FFC107;">Modifier le commentaire</h2>

        <form id="edit-comment-form" style="display: flex; flex-direction: column; gap: 16px;">
            <input type="hidden" id="edit-modal-comment-id" name="comment_id">

            <textarea id="edit-comment-text" name="contenu" placeholder="Votre commentaire..." style="width: 100%; min-height: 120px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 14px 16px; color: #f4f8fc; font-family: 'Poppins', sans-serif; resize: vertical; outline: none; font-size: 14px;"></textarea>

            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button type="button" id="close-edit-modal" class="btn-cancel-post">Annuler</button>
                <button type="submit" class="btn-submit-post">Modifier</button>
            </div>
        </form>
    </div>
</div>

<div id="comment-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; backdrop-filter: blur(4px); align-items: center; justify-content: center; padding: 20px;">
    <div class="comment-modal-box">
        <h2 class="comment-modal-title">Ajouter un commentaire</h2>

        <form id="comment-form" class="comment-modal-form">
            <input type="hidden" id="modal-post-id" name="post_id">
            <input type="hidden" id="comment-gif-url" name="gifUrl">

            <textarea id="comment-text" name="contenu" placeholder="Votre commentaire..." class="comment-modal-textarea"></textarea>
            
            <div id="comment-error-message" class="comment-error-message" style="display:none;"></div>


            <div id="selected-gif-preview" class="selected-gif-preview" style="display:none;">
                <div class="selected-gif-label">GIF sélectionné</div>
                <img id="selected-gif-image" src="" alt="GIF sélectionné" class="selected-gif-image">
                <div style="margin-top:10px;">
                    <button type="button" id="remove-selected-gif" class="btn-cancel-post">Supprimer le GIF</button>
                </div>
            </div>

            <div id="gif-search-box" class="gif-search-box" style="display:none;">
                <div class="gif-search-row">
                    <input
                        type="text"
                        id="gif-search-input"
                        placeholder="Rechercher un GIF..."
                        class="post-input-field gif-search-input"
                    >
                    <button type="button" id="gif-search-btn" class="btn-plan-post">Chercher</button>
                </div>

                <div id="gif-results" class="gif-results-grid"></div>
            </div>

            <div class="comment-modal-actions">
                <button type="button" id="open-gif-search" class="btn-plan-post">GIF</button>
                <button type="button" id="close-modal" class="btn-cancel-post">Annuler</button>
                <button type="submit" class="btn-submit-post">Publier</button>
            </div>
        </form>
    </div>
</div>

<div id="edit-post-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; backdrop-filter: blur(4px); align-items: center; justify-content: center; padding: 20px;">
    <div style="background: #0B2D4A; border: 1px solid rgba(255, 193, 7, 0.2); border-radius: 20px; padding: 32px; max-width: 700px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.5); max-height: 90vh; overflow-y: auto;">
        <h2 style="font-size: 24px; font-weight: 800; margin: 0 0 24px; color: #FFC107;">Modifier le post</h2>

        <form id="edit-post-form" method="post" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 16px;">
            <input
                type="text"
                id="edit-post-title"
                name="titre"
                placeholder="Titre du post..."
                class="post-input-field"
                required
            >

            <select id="edit-post-type" name="type" class="post-input-field" required>
                <option value="Promotion">Promotion</option>
                <option value="Actualité">Actualité</option>
                <option value="Conseil">Conseil</option>
                <option value="Bon plan">Bon plan</option>
            </select>

            <textarea
                id="edit-post-content"
                name="contenu"
                placeholder="Écrire quelque chose..."
                rows="5"
                class="post-textarea-field"
            ></textarea>

            <div id="edit-current-image-wrap" style="display: none;">
                <div style="font-size: 14px; font-weight: 700; color: #f4f8fc; margin-bottom: 10px;">Image actuelle</div>
                <img id="edit-current-image" src="" alt="Image actuelle" class="preview-image">
            </div>

            <div class="native-upload-box">
                <div class="native-upload-title">📷 Changer l’image</div>
                <div class="native-upload-subtitle">Choisis une nouvelle image si tu veux remplacer l’ancienne</div>

                <input type="file" id="edit-post-image" name="imagePath" class="native-file-input" accept="image/*">
                <div id="edit-selected-file-name" class="selected-file-name">Aucun nouveau fichier sélectionné</div>
            </div>

            <div id="edit-image-preview-wrapper" style="display: none;">
                <div style="font-size: 14px; font-weight: 700; color: #f4f8fc; margin-bottom: 10px;">Nouvelle image sélectionnée</div>
                <img id="edit-image-preview" src="" alt="Nouvelle image" class="preview-image">
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button type="button" id="close-edit-post-modal" class="btn-cancel-post">Annuler</button>
                <button type="submit" id="save-edit-post-btn" class="btn-submit-post">Enregistrer</button>
            </div>
        </form>
    </div>
</div>
<div id="report-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; backdrop-filter: blur(4px); align-items: center; justify-content: center; padding: 20px;">
    <div class="report-modal-box">
        <h2 class="report-modal-title">Signaler ce post</h2>

        <form id="report-form" class="report-modal-form">
            <input type="hidden" id="report-post-id" name="post_id">

            <select id="report-reason" name="raison" class="post-input-field" required>
                <option value="">Choisir une raison</option>
                <option value="Spam">Spam</option>
                <option value="Contenu offensant">Contenu offensant</option>
                <option value="Fausse information">Fausse information</option>
                <option value="Harcèlement">Harcèlement</option>
                <option value="Autre">Autre</option>
            </select>

            <textarea
                id="report-details"
                name="details"
                placeholder="Explique la raison du signalement..."
                class="comment-modal-textarea"
                rows="5"
            ></textarea>

            <div id="report-error-message" class="comment-error-message" style="display:none;"></div>
            <div id="report-success-message" class="flash-message flash-success" style="display:none;"></div>

            <div class="comment-modal-actions">
                <button type="button" id="close-report-modal" class="btn-cancel-post">Annuler</button>
                <button type="submit" class="btn-submit-post">Envoyer le signalement</button>
            </div>
        </form>
    </div>
</div>
<div id="news-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:2000; backdrop-filter:blur(6px);">
    
    <div style="
        width:90%;
        max-width:1000px;
        margin:60px auto;
        background:#0B2D4A;
        border-radius:20px;
        padding:30px;
        max-height:85vh;
        overflow-y:auto;
    ">
        
       <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
    <h2 style="color:#FFC107; margin:0;">📰 News</h2>

    <div style="display:flex; align-items:center; gap:10px;">
        <button id="refresh-news-btn" type="button" class="btn-plan-post">🔄 Actualiser</button>
        <button id="close-news-modal" type="button" class="btn-cancel-post">X</button>
    </div>
</div>
        <div id="news-container" style="margin-top:20px;">
            Chargement des news...
        </div>

    </div>
</div>

<style>
    .feed-page {
        min-height: 100vh;
        padding: 120px 24px 60px;
        background: #0B2D4A;
    }

    .feed-layout {
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        display: block;
    }

    .feed-column {
        width: 100%;
        max-width: 820px;
        margin: 0 auto;
    }

    .feed-title {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 30px;
        color: #FFC107;
    }

    .flash-message {
        padding: 14px 18px;
        border-radius: 12px;
        margin-bottom: 16px;
    }

    .flash-success {
        background: rgba(25, 135, 84, 0.2);
        border: 1px solid rgba(25, 135, 84, 0.5);
        color: #d1ffe3;
    }

    .flash-error {
        background: rgba(220, 53, 69, 0.2);
        border: 1px solid rgba(220, 53, 69, 0.5);
        color: #ffd6db;
    }

    .create-post-card,
    .post-card,
    .empty-post-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255, 193, 7, 0.12);
        border-radius: 22px;
        padding: 24px;
        margin-bottom: 24px;
        backdrop-filter: blur(10px);
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.12);
    }

    .create-post-top {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .create-post-input-wrap {
        flex: 1;
    }

    .fake-post-input,
    .post-input-field,
    .post-textarea-field,
    .native-file-input {
        width: 100%;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 14px 16px;
        color: #f4f8fc;
        outline: none;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        box-sizing: border-box;
    }

    .post-input-field::placeholder,
    .post-textarea-field::placeholder,
    .fake-post-input::placeholder {
        color: rgba(244,248,252,0.55);
    }
    .report-action {
    background: rgba(255, 87, 87, 0.18);
    color: #ff7b7b;
}

.report-action:hover {
    background: rgba(255, 87, 87, 0.28);
}

.report-modal-box {
    background: #0B2D4A;
    border: 1px solid rgba(255, 193, 7, 0.2);
    border-radius: 20px;
    padding: 28px;
    width: 100%;
    max-width: 560px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}

.report-modal-title {
    font-size: 24px;
    font-weight: 800;
    margin: 0 0 20px;
    color: #FFC107;
}

.report-modal-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

    .create-post-plus {
        width: 54px;
        height: 54px;
        border: none;
        border-radius: 50%;
        background: linear-gradient(135deg, #FFC107 0%, #FF8F00 100%);
        color: #08263E;
        font-size: 28px;
        cursor: pointer;
        font-weight: 700;
        flex-shrink: 0;
    }

    .post-form-wrapper {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid rgba(255, 193, 7, 0.1);
    }

    .post-form-wrapper form {
        display: block;
        width: 100%;
    }

    .post-form-grid {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 14px;
        margin-bottom: 14px;
    }

    .post-form-block {
        margin-bottom: 14px;
    }

    .post-textarea-field {
        resize: vertical;
        min-height: 120px;
    }

    .native-upload-box {
        border: 2px dashed rgba(255, 193, 7, 0.35);
        border-radius: 16px;
        background: rgba(255,255,255,0.02);
        padding: 24px;
        text-align: center;
    }

    .native-upload-title {
        font-size: 18px;
        font-weight: 700;
        color: #FFC107;
        margin-bottom: 8px;
    }

    .native-upload-subtitle {
        font-size: 13px;
        color: rgba(244,248,252,0.65);
        margin-bottom: 16px;
    }

    .schedule-box {
        border: 2px dashed rgba(46, 168, 255, 0.35);
        border-radius: 16px;
        background: rgba(255,255,255,0.02);
        padding: 20px;
        text-align: left;
    }

    .schedule-title {
        font-size: 18px;
        font-weight: 700;
        color: #2ea8ff;
        margin-bottom: 8px;
    }

    .schedule-subtitle {
        font-size: 13px;
        color: rgba(244,248,252,0.65);
        margin-bottom: 14px;
    }

    .btn-plan-post {
        padding: 12px 30px;
        border: none;
        border-radius: 999px;
        background: linear-gradient(135deg, #2ea8ff 0%, #1d7fe2 100%);
        color: #ffffff;
        font-weight: 700;
        cursor: pointer;
    }

    .selected-file-name {
        font-size: 13px;
        color: #ffffff;
        background: rgba(255,255,255,0.06);
        padding: 8px 14px;
        border-radius: 999px;
        margin-top: 14px;
        display: inline-block;
    }

    .preview-image {
        width: 100%;
        max-height: 320px;
        object-fit: cover;
        border-radius: 14px;
