<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authentification</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(to right, #123d5c, #0b2d4a);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        .auth-container {
            width: 1100px;
            height: 600px;
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
            background: #0B2D4A;
        }

        /* ========== PANNEAU BLEU (OVERLAY) ========== */
        .overlay-panel {
            position: absolute;
            top: 0;
            width: 50%;
            height: 100%;
            background: linear-gradient(135deg, #3bbcff, #1a7acc);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
            transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55),
                        width 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        /* Forme diagonale du panneau */
        .overlay-panel::before {
            content: '';
            position: absolute;
            top: 0;
            width: 100%;
            height: 100%;
            background: inherit;
            z-index: -1;
        }

        .overlay-left {
            left: 0;
            clip-path: polygon(0 0, 85% 0, 65% 100%, 0 100%);
            transform: translateX(0);
        }

        .overlay-right {
            right: 0;
            clip-path: polygon(35% 0, 100% 0, 100% 100%, 15% 100%);
            transform: translateX(0);
        }

        /* Position du panneau quand actif (du côté Register) */
        .auth-container.toggled .overlay-left {
            transform: translateX(100%);
            clip-path: polygon(15% 0, 100% 0, 100% 100%, 35% 100%);
        }

        .auth-container.toggled .overlay-right {
            transform: translateX(-100%);
            clip-path: polygon(0 0, 85% 0, 65% 100%, 0 100%);
        }

        /* Contenu du panneau */


.overlay-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%); /* centre parfait */
    text-align: center;
}

        .overlay-right .overlay-content {
            text-align: center;
            max-width: 280px;
        }

        .overlay-content h1 {
            font-size: 42px;
            font-weight: bold;
            margin-bottom: 15px;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
            letter-spacing: 2px;
        }

        .overlay-content p {
            font-size: 16px;
            color: #cceeff;
            line-height: 1.6;
        }

        /* Boutons dans le panneau */
        .overlay-btn {
            margin-top: 30px;
            padding: 14px 40px;
            background: transparent;
            border: 2px solid white;
            border-radius: 30px;
            color: white;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .overlay-btn:hover {
            background: white;
            color: #1a7acc;
        }

        /* ========== FORMULAIRES ========== */
        .form-panel {
            position: absolute;
            top: 0;
            width: 50%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px 60px;
            z-index: 5;
            transition: opacity 0.5s ease, transform 0.5s ease, z-index 0.5s ease;
        }

        /* Formulaire Login (gauche) */
        .login-panel {
            left: 0;
            opacity: 1;
            transform: translateX(0);
        }

        /* Formulaire Register (droite) */
        .register-panel {
            right: 0;
            opacity: 1;
            transform: translateX(0);
        }

        /* État togglé - les formulaires changent de position */
        .auth-container.toggled .login-panel {
            opacity: 0;
            transform: translateX(-50px);
            z-index: 1;
        }

        .auth-container.toggled .register-panel {
            opacity: 1;
            transform: translateX(0);
            z-index: 10;
        }

        /* Formulaires masqués par défaut (mobile) */
        @media (max-width: 768px) {
            .login-panel {
                opacity: 0;
                transform: translateX(-50px);
                z-index: 1;
            }
            
            .register-panel {
                opacity: 0;
                transform: translateX(50px);
                z-index: 1;
            }
            
            .auth-container.toggled .login-panel {
                opacity: 1;
                transform: translateX(0);
                z-index: 10;
            }
            
            .auth-container.toggled .register-panel {
                opacity: 0;
                transform: translateX(50px);
                z-index: 1;
            }
        }

        .form-panel h2 {
            font-size: 34px;
            margin-bottom: 35px;
            font-weight: bold;
            color: white;
        }

        .form-panel form {
            width: 100%;
            max-width: 350px;
        }

        /* Inputs */
        .form-panel input {
            width: 100%;
            padding: 15px 5px;
            margin-bottom: 25px;
            border: none;
            border-bottom: 2px solid rgba(47, 168, 255, 0.4);
            background: transparent;
            color: white;
            font-size: 15px;
            outline: none;
            transition: border-color 0.3s ease;
        }

        .form-panel input:focus {
            border-bottom-color: #2FA8FF;
        }

        .form-panel input::placeholder {
            color: #7aacc5;
        }

        /* Rangées de formulaire */
        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 0;
        }

        .form-row .input-group {
            flex: 1;
        }

        .input-group {
            position: relative;
            margin-bottom: 25px;
        }

        .input-group input {
            margin-bottom: 0;
        }

        .error-message {
            color: #ff6b6b;
            font-size: 12px;
            margin-top: 5px;
            min-height: 16px;
        }

        /* Bouton principal */
        .btn-submit {
            width: 100%;
            padding: 15px;
            background: linear-gradient(120deg, #FFC107, #FF8F00);
            border: none;
            border-radius: 30px;
            color: white;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
            box-shadow: 0 6px 20px rgba(255, 193, 7, 0.3);
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 28px rgba(255, 193, 7, 0.45);
        }

        .btn-submit:active {
            transform: translateY(-1px);
        }

        /* Lien texte */
        .form-panel p {
            margin-top: 25px;
            color: #7aacc5;
            font-size: 14px;
        }

        .form-panel a {
            color: #a777ff;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
            cursor: pointer;
        }

        .form-panel a:hover {
            color: #c9aaff;
        }

        /* ========== ANIMATIONS D'ENTRÉE ========== */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .form-panel h2 {
            animation: fadeInUp 0.6s ease forwards;
        }

        .form-panel form {
            animation: fadeInUp 0.6s ease 0.1s forwards;
            opacity: 0;
        }

        .form-panel p {
            animation: fadeInUp 0.6s ease 0.2s forwards;
            opacity: 0;
        }

        .overlay-content h1 {
            animation: fadeInUp 0.6s ease 0.3s forwards;
            opacity: 0;
        }

        .overlay-content p {
            animation: fadeInUp 0.6s ease 0.4s forwards;
            opacity: 0;
        }

        .overlay-btn {
            animation: fadeInUp 0.6s ease 0.5s forwards;
            opacity: 0;
        }

        /* Animation du texte du panneau lors du toggle */
        .overlay-content .welcome-text,
        .overlay-content .switch-text {
            transition: opacity 0.3s ease, transform 0.3s ease;
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 1024px) {
            .auth-container {
                width: 95%;
                height: auto;
                min-height: 600px;
            }
        }

        @media (max-width: 768px) {
            .auth-container {
                width: 100%;
                height: 100vh;
                border-radius: 0;
            }

            .overlay-panel {
                display: none;
            }

            .form-panel {
                width: 100%;
                padding: 30px;
            }

            .auth-container.toggled .login-panel,
            .auth-container.toggled .register-panel {
                opacity: 1;
                transform: translateX(0);
            }

            .form-row {
                flex-direction: column;
                gap: 0;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container" id="authContainer">
        <!-- Panneau Gauche (Welcome Back) -->
        <div class="overlay-panel overlay-left">
            <div class="overlay-content">
                <h1>WELCOME BACK!</h1>
                <p>Content de vous revoir ! Connectez-vous pour continuer votre expérience.</p>
                <button class="overlay-btn" onclick="toggleAuth('login')">Se connecter</button>
            </div>
        </div>

        <!-- Panneau Droit (Welcome) -->
        <div class="overlay-panel overlay-right">
            <div class="overlay-content">
                <h1>WELCOME!</h1>
                <p>Rejoignez-nous ! Créez un compte pour commencer votre aventure.</p>
                <button class="overlay-btn" onclick="toggleAuth('register')">S'inscrire</button>
            </div>
        </div>

        <!-- Formulaire Login -->
        <div class="form-panel login-panel">
            <h2>Connexion</h2>
            <form method="post" action="{{ path('app_login') }}">
                <input type="email" name="_username" placeholder="Email" required>
                <input type="password" name="_password" placeholder="Mot de passe" required>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" class="btn-submit">Se connecter</button>
            </form>
            {% if error %}
                <div style="color: #ff6b6b; margin-top: 15px;">Email ou mot de passe incorrect</div>
            {% endif %}
            <p>Pas encore de compte ? <a onclick="toggleAuth('register')">Créer un compte</a></p>
        </div>

        <!-- Formulaire Register -->
        <div class="form-panel register-panel">
            <h2>Inscription</h2>
            <form method="post" action="{{ path('app_register') }}" enctype="multipart/form-data">
                <div class="form-row">
                    <div class="input-group">
                        <input type="text" name="nom" placeholder="Nom" required>
                        <div class="error-message"></div>
                    </div>
                    <div class="input-group">
                        <input type="text" name="prenom" placeholder="Prénom" required>
                        <div class="error-message"></div>
                    </div>
                </div>
                <input type="email" name="email" placeholder="Email" required>
                <input type="text" name="telephone" placeholder="Téléphone" required>
                <input type="password" name="password" placeholder="Mot de passe" required>
                <input type="password" name="confirm_password" placeholder="Confirmer le mot de passe" required>
                <input type="file" name="image" accept="image/*">
                <button type="submit" class="btn-submit">S'inscrire</button>
            </form>
            <p>Déjà un compte ? <a onclick="toggleAuth('login')">Se connecter</a></p>
        </div>
    </div>

    <script>
        function toggleAuth(target) {
            const container = document.getElementById('authContainer');
            
            if (target === 'register' && !container.classList.contains('toggled')) {
                container.classList.add('toggled');
            } else if (target === 'login' && container.classList.contains('toggled')) {
                container.classList.remove('toggled');
            }
        }

        // Animation au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            // Ajouter une classe pour démarrer les animations
            setTimeout(() => {
                document.querySelectorAll('.form-panel, .overlay-content').forEach(el => {
                    el.style.animationPlayState = 'running';
                });
            }, 100);
        });
    </script>
</body>
</html>
