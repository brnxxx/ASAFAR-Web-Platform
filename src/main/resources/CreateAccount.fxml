<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.CreateAccountController"
            stylesheets="@/create-account.css"
            styleClass="auth-background">

    <HBox AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <!-- left form-->
        <VBox alignment="CENTER"
              spacing="18"
              HBox.hgrow="ALWAYS"
              style="-fx-padding:60;">

            <Label text="Créer un Compte"
                   styleClass="auth-title"/>

            <Button text="Choisir image"
                    onAction="#handleUploadImage"
                    styleClass="btn-auth"/>

            <ImageView fx:id="imageViewUser"
                       fitWidth="120"
                       fitHeight="120"
                       preserveRatio="true"
                       styleClass="profile-preview"/>

            <!-- nom -->
            <VBox spacing="3" alignment="CENTER_LEFT" maxWidth="320">
                <TextField fx:id="tfNom"
                           promptText="Nom"
                           styleClass="input-field"
                           maxWidth="320"/>

                <Label fx:id="errNom"
                       visible="false"
                       managed="false"
                       styleClass="error-text"/>
            </VBox>


            <!-- prenom -->
            <VBox spacing="3" alignment="CENTER_LEFT" maxWidth="320">
                <TextField fx:id="tfPrenom"
                           promptText="Prénom"
                           styleClass="input-field"
                           maxWidth="320"/>

                <Label fx:id="errPrenom"
                       visible="false"
                       managed="false"
                       styleClass="error-text"/>
            </VBox>


            <!-- mail -->
            <VBox spacing="3" alignment="CENTER_LEFT" maxWidth="320">
                <TextField fx:id="tfEmail"
                           promptText="Email"
                           styleClass="input-field"
                           maxWidth="320"/>

                <Label fx:id="errEmail"
                       visible="false"
                       managed="false"
                       styleClass="error-text"/>
            </VBox>


            <!-- tel -->
            <VBox spacing="3" alignment="CENTER_LEFT" maxWidth="320">
                <TextField fx:id="tfTel"
                           promptText="Téléphone (8 chiffres)"
                           styleClass="input-field"
                           maxWidth="320"/>

                <Label fx:id="errTel"
                       visible="false"
                       managed="false"
                       styleClass="error-text"/>
            </VBox>


            <!-- psswd -->
            <VBox spacing="3" alignment="CENTER_LEFT" maxWidth="320">
                <PasswordField fx:id="tfPassword"
                               promptText="Mot de passe"
                               styleClass="input-field"
                               maxWidth="320"/>

                <Label fx:id="errPassword"
                       visible="false"
                       managed="false"
                       styleClass="error-text"/>
            </VBox>


            <!-- confirm psswd -->
            <VBox spacing="3" alignment="CENTER_LEFT" maxWidth="320">
                <PasswordField fx:id="tfConfirmPassword"
                               promptText="Confirmer mot de passe"
                               styleClass="input-field"
                               maxWidth="320"/>

                <Label fx:id="errConfirm"
                       visible="false"
                       managed="false"
                       styleClass="error-text"/>
            </VBox>


            <Label fx:id="lblError"
                   visible="false"
                   managed="false"
                   wrapText="true"
                   maxWidth="320"
                   alignment="CENTER"
                   styleClass="error-text"/>

            <Button text="Créer mon compte"
                    styleClass="btn-auth"
                    onAction="#handleCreateAccount"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Déjà un compte ?"
                       styleClass="auth-text"/>

                <Hyperlink text="Se connecter"
                           styleClass="auth-link"
                           onAction="#handleLoginRedirect"/>
            </HBox>

        </VBox>


        <StackPane HBox.hgrow="ALWAYS">

            <Pane fx:id="welcomePane"
                  styleClass="welcome-panel"
                  maxWidth="Infinity"
                  maxHeight="Infinity"/>

            <VBox alignment="CENTER" spacing="10">
                <Label text="WELCOME!"
                       styleClass="welcome-text"/>

                <Label text="Créer votre compte pour commencer"
                       styleClass="auth-text"/>
            </VBox>

        </StackPane>

    </HBox>

</AnchorPane>
