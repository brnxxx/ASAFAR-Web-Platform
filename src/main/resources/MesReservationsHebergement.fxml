<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<BorderPane stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.MesReservationsHebergementController">

    <!-- ================= TOP HEADER ================= -->
    <top>
        <VBox>
            <!-- Bouton retour -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets left="20" top="10"/>
                </padding>

                <Button fx:id="btnBack"
                        onAction="#onRetour"
                        styleClass="icon-button-flat">
                    <graphic>
                        <ImageView fitHeight="26" preserveRatio="true">
                            <image>
                                <Image url="@/images/retour.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnRetourSidebar"
                        onAction="#onRetourSidebar"
                        styleClass="icon-button-flat"
                        text="Retour à l'accueil">
                    <graphic>
                        <ImageView fitHeight="26" preserveRatio="true">
                            <image>
                                <Image url="@/images/home.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </HBox>

            <!-- HERO HEADER -->
            <VBox spacing="10" styleClass="hero" alignment="CENTER">
                <padding>
                    <Insets bottom="20" left="40" right="40" top="20"/>
                </padding>

                <Label styleClass="hero-title" text="Mes Réservations d'hébergement"/>
                <Label styleClass="hero-subtitle" text="Consultez et gérez vos réservations d'hébergement"/>
            </VBox>
        </VBox>
    </top>

    <!-- ================= CENTER CONTENT ================= -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="15">
            <padding>
                <Insets bottom="20" left="40" right="40" top="20"/>
            </padding>

            <!-- Compteur -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Total réservations : " style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                <Label fx:id="lblTotal" style="-fx-text-fill: #FF8F00; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- LISTVIEW -->
            <ListView fx:id="listViewReservation"
                      prefHeight="500"
                      styleClass="reservation-list"/>
        </VBox>
    </center>

</BorderPane>