<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.LoginController">

    <StackPane AnchorPane.topAnchor="0"
               AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0">

        <!-- MAIN CARD -->
        <HBox styleClass="auth-card"
              alignment="CENTER"
              prefWidth="700"
              prefHeight="420">

            <!-- ================= LEFT PANEL ================= -->
            <StackPane prefWidth="350" prefHeight="420" HBox.hgrow="ALWAYS">

                <Pane fx:id="welcomePane"
                      prefWidth="350"
                      prefHeight="420"
                      styleClass="welcome-panel"/>

                <VBox alignment="CENTER" spacing="10">
                    <Label text="WELCOME!" styleClass="welcome-text"/>
                    <Label text="Connectez-vous pour continuer"
                           styleClass="auth-text"/>
                </VBox>

            </StackPane>

            <!-- ================= RIGHT PANEL ================= -->
            <VBox alignment="CENTER"
                  spacing="18"
                  prefWidth="350"
                  HBox.hgrow="ALWAYS"
                  style="-fx-padding:40;">

                <Label text="Connexion"
                       styleClass="auth-title"/>

                <!-- EMAIL -->
                <TextField fx:id="txtEmail"
                           promptText="Email"
                           styleClass="input-field"
                           maxWidth="260"/>

                <!-- PASSWORD -->
                <PasswordField fx:id="txtPassword"
                               promptText="Mot de passe"
                               styleClass="input-field"
                               maxWidth="260"/>

                <!-- LOGIN -->
                <Button text="Se connecter"
                        onAction="#handleLogin"
                        styleClass="btn-auth"
                        prefWidth="220"/>

                <!-- ERROR -->
                <Label fx:id="lblError"
                       textFill="red"
                       style="-fx-font-size:13px;"/>

                <!-- ================= SEPARATOR ================= -->
                <HBox alignment="CENTER" spacing="10">
                    <Separator prefWidth="80"/>
                    <Label text="OU"
                           style="-fx-text-fill:#8fbcd4; -fx-font-size:12px;"/>
                    <Separator prefWidth="80"/>
                </HBox>

                <!-- ================= FACE ID ================= -->
                <VBox alignment="CENTER" spacing="10">

                    <Button fx:id="btnFaceID"
                            text="Connexion FaceID"
                            onAction="#handleFaceLogin"
                            styleClass="btn-face"
                            prefWidth="220"/>

                    <Label fx:id="lblFaceStatus"
                           text=""
                           style="-fx-text-fill:#ffcc00; -fx-font-size:12px;"/>
                </VBox>

                <!-- REGISTER -->
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Pas encore de compte ?"
                           styleClass="auth-text"/>

                    <Hyperlink text="Créer un compte"
                               onAction="#handleRegisterRedirect"
                               styleClass="auth-link"/>
                </HBox>

            </VBox>

        </HBox>

    </StackPane>

</AnchorPane>
