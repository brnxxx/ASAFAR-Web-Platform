<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900" prefWidth="1400"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            stylesheets="@style.css,@admin.css"
            fx:controller="tn.esprit.controllers.ReclamationBackController">

    <center>
        <VBox spacing="25" styleClass="admin-root">

            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- TITLE -->
            <HBox alignment="CENTER_LEFT">
                <Label text="Gestion des Réclamations"
                       styleClass="section-title"/>
            </HBox>

            <!-- TABLE -->
            <TableView fx:id="tableReclamations"
                       styleClass="admin-table"
                       VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="60"/>

                    <TableColumn fx:id="colSujet"
                                 text="Sujet"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colDescription"
                                 text="Description"
                                 prefWidth="300"/>

                    <TableColumn fx:id="colDate"
                                 text="Date"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colStatut"
                                 text="Statut"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colReponse"
                                 text="Réponse Admin"
                                 prefWidth="250"/>

                    <TableColumn fx:id="colActions"
                                 text="Actions"
                                 prefWidth="180"/>

                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>
