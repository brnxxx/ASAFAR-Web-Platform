<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.ReservationHebergementPopupController"
      spacing="15"
      alignment="CENTER"
      prefWidth="450"
      style="-fx-background-color: linear-gradient(to bottom, #1E3B5A, #2A4F6E);
             -fx-background-radius: 15;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 20, 0, 0, 10);">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- ================= TITRE ================= -->
    <Label text="Réservation d'hébergement"
           style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

    <Label fx:id="lblHebergementNom"
           style="-fx-text-fill: #FF8F00; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label fx:id="lblPrixParNuit"
           style="-fx-text-fill: #A7E3FF; -fx-font-size: 14px;"/>

    <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

    <!-- ================= INFORMATIONS CLIENT ================= -->
    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints percentWidth="30"/>
            <ColumnConstraints percentWidth="70"/>
        </columnConstraints>

        <!-- Nom -->
        <Label text="Nom complet :" style="-fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNomClient" promptText="Votre nom" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8;"/>

        <!-- Email -->
        <Label text="Email :" style="-fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtEmail" promptText="votre@email.com" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8;"/>

        <!-- Téléphone -->
        <Label text="Téléphone :" style="-fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTelephone" promptText="12345678" GridPane.rowIndex="2" GridPane.columnIndex="1"
                   style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8;"/>
    </GridPane>

    <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

    <!-- ================= DATES ================= -->
    <HBox spacing="15" alignment="CENTER">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Arrivée" style="-fx-text-fill: #A7E3FF; -fx-font-size: 12px;"/>
            <DatePicker fx:id="dateArrivee" prefWidth="180"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Départ" style="-fx-text-fill: #A7E3FF; -fx-font-size: 12px;"/>
            <DatePicker fx:id="dateDepart" prefWidth="180"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;"/>
        </VBox>
    </HBox>

    <!-- ================= PERSONNES ================= -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Nombre de personnes :" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
        <Spinner fx:id="spinnerPersonnes" prefWidth="100" editable="true"/>
    </HBox>

    <!-- ================= TOTAL ================= -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Prix total :" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label fx:id="lblPrixTotal" text="0 DT"
               style="-fx-text-fill: #FF8F00; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Label fx:id="lblNbNuits" text="(0 nuits)" style="-fx-text-fill: #A7E3FF;"/>
    </HBox>

    <!-- ================= BOUTONS ================= -->
    <HBox spacing="15" alignment="CENTER">
        <Button text="CONFIRMER"
                onAction="#confirmerReservation"
                prefWidth="150"
                prefHeight="40"
                style="-fx-background-color: #FF8F00; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>

        <Button text="ANNULER"
                onAction="#annuler"
                prefWidth="150"
                prefHeight="40"
                style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>