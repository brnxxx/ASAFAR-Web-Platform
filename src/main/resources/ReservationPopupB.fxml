<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.ReservationPopupControllerB"
      stylesheets="@styleB.css"
      spacing="20"
      alignment="CENTER"
      prefWidth="360"
      style="-fx-background-color: linear-gradient(to right,#0b2d4a,#1e6fa8);
             -fx-background-radius:15;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- ================= DATE ================= -->
    <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="Infinity">
        <Label text="Date excursion" styleClass="search-label"/>

        <DatePicker fx:id="datePicker"
                    maxWidth="Infinity"
                    styleClass="search-field"/>
    </VBox>

    <!-- ================= ADULTE ================= -->
    <HBox alignment="CENTER_LEFT" spacing="15">

        <Label fx:id="lblPrixAdulte"
               text="Adulte (0.00 DT)"
               style="-fx-text-fill:white; -fx-font-size:14px;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- compteur -->
        <HBox alignment="CENTER" spacing="10" styleClass="counter-box">

            <Button onAction="#minusAdult" styleClass="icon-button-flat">
                <graphic>
                    <ImageView fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@/images/moins.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <Label fx:id="lblAdult"
                   text="0"
                   minWidth="28"
                   alignment="CENTER"
                   style="-fx-text-fill:white; -fx-font-size:15px;"/>

            <Button onAction="#plusAdult" styleClass="icon-button-flat">
                <graphic>
                    <ImageView fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@/images/plus.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

        </HBox>

    </HBox>

    <!-- ================= ENFANT ================= -->
    <HBox alignment="CENTER_LEFT" spacing="15">

        <Label fx:id="lblPrixEnfant"
               text="Enfant (0.00 DT)"
               style="-fx-text-fill:white; -fx-font-size:14px;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox alignment="CENTER" spacing="10" styleClass="counter-box">

            <Button onAction="#minusChild" styleClass="icon-button-flat">
                <graphic>
                    <ImageView fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@/images/moins.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <Label fx:id="lblChild"
                   text="0"
                   minWidth="28"
                   alignment="CENTER"
                   style="-fx-text-fill:white; -fx-font-size:15px;"/>

            <Button onAction="#plusChild" styleClass="icon-button-flat">
                <graphic>
                    <ImageView fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@/images/plus.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

        </HBox>

    </HBox>


    <!-- ================= BEBE ================= -->
    <HBox alignment="CENTER_LEFT" spacing="15">

        <Label fx:id="lblPrixBebe"
               text="Bébé (0.00 DT)"
               style="-fx-text-fill:white; -fx-font-size:14px;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox alignment="CENTER" spacing="10" styleClass="counter-box">

            <Button onAction="#minusBaby" styleClass="icon-button-flat">
                <graphic>
                    <ImageView fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@/images/moins.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <Label fx:id="lblBaby"
                   text="0"
                   minWidth="28"
                   alignment="CENTER"
                   style="-fx-text-fill:white; -fx-font-size:15px;"/>

            <Button onAction="#plusBaby" styleClass="icon-button-flat">
                <graphic>
                    <ImageView fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@/images/plus.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

        </HBox>

    </HBox>

    <!-- ================= TOTAL ================= -->
    <Label fx:id="lblTotal"
           text="Total : 0.00 DT"
           style="-fx-text-fill:#2FA8FF;
                  -fx-font-size:18px;
                  -fx-font-weight:bold;"/>

    <!-- ================= CONFIRMER ================= -->
    <Button text="Confirmer"
            prefWidth="180"
            prefHeight="42"
            onAction="#confirmerReservation"
            style="
                -fx-background-radius:8;
                -fx-background-color: linear-gradient(to right,#ff8c00,#ff6a00);
                -fx-text-fill:white;
                -fx-font-weight:bold;
                -fx-font-size:14px;
                -fx-cursor:hand;"/>

</VBox>
