<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>

<BorderPane prefHeight="900" prefWidth="1400" stylesheets="@styleA.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.FrontOfficeControllerA">

    <!-- ================= SIDEBAR ================= -->
    <left>
        <StackPane fx:id="leftContainer" maxWidth="300" minWidth="100" onMouseEntered="#expandSidebar" onMouseExited="#collapseSidebar" prefWidth="100">

            <VBox alignment="TOP_CENTER" spacing="30" styleClass="sidebar">

                <padding>
                    <Insets left="15" right="15" top="25" />
                </padding>

                <!-- LOGO -->
                <ImageView fx:id="logo" fitHeight="55" preserveRatio="true">
                    <image>
                        <Image url="@/images/logo.png" />
                    </image>
                </ImageView>

                <!-- MENU -->
                <Button fx:id="btnAccueil" styleClass="menu-btn" text="ACCUEIL">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/home.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnHebergement" styleClass="menu-btn" text="HÉBERGEMENTS">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/building.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnLoisirs" styleClass="menu-btn" text="LOISIRS">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/parc.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnTransport" styleClass="menu-btn-active" text="TRANSPORTS">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/transport.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnAvis"
                        styleClass="menu-btn"
                        text="RÉCLAMATIONS"
                        onAction="#openReclamations">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/avis.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>


            </VBox>
        </StackPane>
    </left>

    <!-- ================= CENTER ADMIN ================= -->
    <!-- ================= CENTER ADMIN ================= -->
    <center>

        <!-- ✅ Container dynamique -->
        <StackPane fx:id="contentArea">

            <!-- ✅ Page par défaut (Transports) -->
            <VBox spacing="30"
                  styleClass="admin-root">

                <padding>
                    <Insets bottom="30" left="40" right="40" top="30" />
                </padding>

                <!-- ===== TOP BAR ===== -->
                <HBox fx:id="topBar"
                      alignment="CENTER_RIGHT"
                      spacing="25"
                      styleClass="topbar-fused">

                    <HBox alignment="CENTER" spacing="10">
                        <Circle fx:id="profileCircle"
                                radius="18"
                                styleClass="user-avatar"
                                onMouseClicked="#openProfile"/>

                        <Button fx:id="btnLogout"
                                styleClass="top-icon-btn"
                                onAction="#handleLogout">

                            <graphic>
                                <ImageView fitHeight="20" preserveRatio="true">
                                    <image>
                                        <Image url="@/images/logout.png" />
                                    </image>
                                </ImageView>
                            </graphic>

                        </Button>
                    </HBox>
                </HBox>

                <!-- ===== LIST + MAP SECTION ===== -->
                <VBox spacing="20"
                      styleClass="admin-table-container"
                      VBox.vgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-title" text="Transports"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnReserve"
                                styleClass="btn-primary"
                                text="Réserver"
                                onAction="#openReservationPopup"/>
                    </HBox>

                    <!-- MAIN CONTENT -->
                    <HBox spacing="25" VBox.vgrow="ALWAYS">

                        <!-- LIST -->
                        <VBox prefWidth="600"
                              spacing="20"
                              HBox.hgrow="ALWAYS">

                            <ListView fx:id="transportListView"
                                      styleClass="admin-list"
                                      VBox.vgrow="ALWAYS"/>
                        </VBox>

                        <!-- MAP -->
                        <StackPane fx:id="mapContainer"
                                   prefWidth="450"
                                   styleClass="map-container">

                            <WebView fx:id="mapView"
                                     prefHeight="500"
                                     prefWidth="450"/>

                            <Button fx:id="btnExpandMap"
                                    styleClass="map-expand-btn"
                                    text="⤢"
                                    StackPane.alignment="TOP_RIGHT"/>
                        </StackPane>

                    </HBox>

                </VBox>

            </VBox>

        </StackPane>

    </center>


</BorderPane>
