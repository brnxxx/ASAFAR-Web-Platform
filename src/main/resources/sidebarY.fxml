<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="800" prefWidth="1300"
            stylesheets="@styleY.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.sidebarYController">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <StackPane fx:id="leftContainer"
                   maxWidth="300"
                   minWidth="100"
                   prefWidth="100"
                   onMouseEntered="#expandSidebar"
                   onMouseExited="#collapseSidebar">

            <VBox alignment="TOP_CENTER" spacing="30" styleClass="sidebar">
                <padding>
                    <Insets left="15" right="15" top="20"/>
                </padding>

                <!-- LOGO -->
                <ImageView fx:id="logo" fitHeight="60" preserveRatio="true">
                    <image>
                        <Image url="@/images/logo.png"/>
                    </image>
                </ImageView>

                <!-- MENU -->
                <Button fx:id="btnAccueil" styleClass="menu-btn" text="ACCUEIL">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/home.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnHebergement" styleClass="menu-btn-active" text="HÉBERGEMENTS">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/building.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnExcursions" styleClass="menu-btn" text="EXCURSIONS"
                        onAction="#openExcursions">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/parc.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnTransport" styleClass="menu-btn" text="TRANSPORTS">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/transport.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnAvis"
                        styleClass="menu-btn"
                        text="RÉCLAMATIONS"
                        onAction="#openReclamations">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/avis.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnReservation"
                        prefHeight="50"
                        prefWidth="250"
                        styleClass="menu-btn"
                        onAction="#openReservations">
                    <graphic>
                        <ImageView fitHeight="18" preserveRatio="true">
                            <image>
                                <Image url="@/images/booking.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

            </VBox>
        </StackPane>
    </left>

    <!-- ================= CENTER ================= -->
    <center>
        <VBox spacing="0">

            <!-- TOP BAR -->
            <HBox fx:id="topBar"
                  alignment="CENTER_RIGHT"
                  spacing="25"
                  styleClass="topbar-fused">

                <padding>
                    <Insets top="15" right="25" bottom="15" left="25"/>
                </padding>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- NOTIFICATION BUTTON -->
                <Button fx:id="btnNotif" styleClass="notification-btn">
                    <graphic>
                        <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                            <image>
                                <Image url="@/images/notif.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- PROFILE CIRCLE -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fx:id="profileCircle"
                            radius="18"
                            styleClass="user-avatar"
                            onMouseClicked="#openProfile"/>
                </HBox>

            </HBox>

            <!-- CONTENT AREA -->
            <StackPane fx:id="contentArea"
                       styleClass="content"
                       VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

</BorderPane>